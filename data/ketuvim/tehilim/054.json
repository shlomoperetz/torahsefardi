  "chapter": 54,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "לַמְנַצֵּ֥חַ בִּנְגִינֹ֗ת מַשְׂכִּ֥יל לְדָוִֽד׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "בְּבֹ֣א הַ֭זִּיפִים וַיֹּאמְר֣וּ לְשָׁא֑וּל הֲלֹ֥א דָ֝וִ֗ד מִסְתַּתֵּ֥ר עִמָּֽנוּ׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "אֱ֭לֹהִים בְּשִׁמְךָ֣ הוֹשִׁיעֵ֑נִי וּבִגְבוּרָתְךָ֥ תְדִינֵֽנִי׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "אֱ֭לֹהִים שְׁמַ֣ע תְּפִלָּתִ֑י הַ֝אֲזִ֗ינָה לְאִמְרֵי־פִֽי׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "כִּ֤י זָרִ֨ים&thinsp;<b>׀</b> קָ֤מוּ עָלַ֗י וְֽ֭עָרִיצִים בִּקְשׁ֣וּ נַפְשִׁ֑י לֹ֤א שָׂ֨מוּ אֱלֹהִ֖ים לְנֶגְדָּ֣ם סֶֽלָה׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "הִנֵּ֣ה אֱ֭לֹהִים עֹזֵ֣ר לִ֑י אֲ֝דֹנָ֗י בְּֽסֹמְכֵ֥י נַפְשִֽׁי׃",
      "es": ""
    },
    {
      "num": 7,
      "he": "<span class=\"mam-kq\"><span class=\"mam-kq-k\">(ישוב)</span> <span class=\"mam-kq-q\">[יָשִׁ֣יב]</span></span> הָ֭רַע לְשֹׁרְרָ֑י בַּ֝אֲמִתְּךָ֗ הַצְמִיתֵֽם׃",
      "es": ""
    },
    {
      "num": 8,
      "he": "בִּנְדָבָ֥ה אֶזְבְּחָה־לָּ֑ךְ א֤וֹדֶה<span class=\"mam-implicit-maqaf\">־</span>שִּׁמְךָ֖ יְהֹוָ֣ה כִּי־טֽוֹב׃",
      "es": ""
    },
    {
      "num": 9,
      "he": "כִּ֣י מִכׇּל־צָ֭רָה הִצִּילָ֑נִי וּ֝בְאֹיְבַ֗י רָאֲתָ֥ה עֵינִֽי׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    }
  ]
