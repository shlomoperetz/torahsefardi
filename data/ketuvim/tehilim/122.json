{
  "book": "tehilim",
  "book_he": "תְּהִלִּים",
  "book_es": "Salmos",
  "chapter": 122,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "שִׁ֥יר הַֽמַּעֲל֗וֹת לְדָ֫וִ֥ד שָׂ֭מַחְתִּי בְּאֹמְרִ֣ים לִ֑י בֵּ֖ית יְהֹוָ֣ה נֵלֵֽךְ׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "עֹ֭מְדוֹת הָי֣וּ רַגְלֵ֑ינוּ בִּ֝שְׁעָרַ֗יִךְ יְרוּשָׁלָֽ͏ִם׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "יְרוּשָׁלַ֥͏ִם הַבְּנוּיָ֑ה כְּ֝עִ֗יר שֶׁחֻבְּרָה־לָּ֥הּ יַחְדָּֽו׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "שֶׁשָּׁ֨ם עָל֪וּ שְׁבָטִ֡ים שִׁבְטֵי־יָ֭הּ עֵד֣וּת לְיִשְׂרָאֵ֑ל לְ֝הֹד֗וֹת לְשֵׁ֣ם יְהֹוָֽה׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "כִּ֤י שָׁ֨מָּה&thinsp;<b>׀</b> יָשְׁב֣וּ כִסְא֣וֹת לְמִשְׁפָּ֑ט כִּ֝סְא֗וֹת לְבֵ֣ית דָּוִֽד׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "שַׁ֭אֲלוּ שְׁל֣וֹם יְרוּשָׁלָ֑͏ִם יִ֝שְׁלָ֗יוּ אֹהֲבָֽיִךְ׃",
      "es": ""
    },
    {
      "num": 7,
      "he": "יְהִי־שָׁל֥וֹם בְּחֵילֵ֑ךְ שַׁ֝לְוָ֗ה בְּאַרְמְנוֹתָֽיִךְ׃",
      "es": ""
    },
    {
      "num": 8,
      "he": "לְ֭מַעַן אַחַ֣י וְרֵעָ֑י אֲדַבְּרָה־נָּ֖א שָׁל֣וֹם בָּֽךְ׃",
      "es": ""
    },
    {
      "num": 9,
      "he": "לְ֭מַעַן בֵּית־יְהֹוָ֣ה אֱלֹהֵ֑ינוּ אֲבַקְשָׁ֖ה ט֣וֹב לָֽךְ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    }
  ]
}