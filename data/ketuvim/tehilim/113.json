{
  "book": "tehilim",
  "book_he": "תְּהִלִּים",
  "book_es": "Salmos",
  "chapter": 113,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "הַ֥לְלוּ<span class=\"mam-implicit-maqaf\">־</span>יָ֨הּ&thinsp;<b>׀</b> הַ֭לְלוּ עַבְדֵ֣י יְהֹוָ֑ה הַֽ֝לְל֗וּ אֶת־שֵׁ֥ם יְהֹוָֽה׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "יְהִ֤י שֵׁ֣ם יְהֹוָ֣ה מְבֹרָ֑ךְ מֵ֝עַתָּ֗ה וְעַד־עוֹלָֽם׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "מִמִּזְרַח־שֶׁ֥מֶשׁ עַד־מְבוֹא֑וֹ מְ֝הֻלָּ֗ל שֵׁ֣ם יְהֹוָֽה׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "רָ֖ם עַל־כׇּל־גּוֹיִ֥ם&thinsp;<small>׀</small>&thinsp;יְהֹוָ֑ה עַ֖ל הַשָּׁמַ֣יִם כְּבוֹדֽוֹ׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "מִ֭י כַּיהֹוָ֣ה אֱלֹהֵ֑ינוּ הַֽמַּגְבִּיהִ֥י לָשָֽׁבֶת׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "הַֽמַּשְׁפִּילִ֥י לִרְא֑וֹת בַּשָּׁמַ֥יִם וּבָאָֽרֶץ׃",
      "es": ""
    },
    {
      "num": 7,
      "he": "מְקִ֥ימִ֣י מֵעָפָ֣ר דָּ֑ל מֵ֝אַשְׁפֹּ֗ת יָרִ֥ים אֶבְיֽוֹן׃",
      "es": ""
    },
    {
      "num": 8,
      "he": "לְהוֹשִׁיבִ֥י עִם־נְדִיבִ֑ים עִ֝֗ם נְדִיבֵ֥י עַמּֽוֹ׃",
      "es": ""
    },
    {
      "num": 9,
      "he": "מֽוֹשִׁיבִ֨י&thinsp;<b>׀</b> עֲקֶ֬רֶת הַבַּ֗יִת אֵֽם־הַבָּנִ֥ים שְׂמֵחָ֗ה הַֽלְלוּ־יָֽהּ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    }
  ]
}