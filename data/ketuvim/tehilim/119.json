{
  "book": "tehilim",
  "book_he": "תְּהִלִּים",
  "book_es": "Salmos",
  "chapter": 119,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "אַשְׁרֵ֥י תְמִֽימֵי־דָ֑רֶךְ הַ֝הֹלְכִ֗ים בְּתוֹרַ֥ת יְהֹוָֽה׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "אַ֭שְׁרֵי נֹצְרֵ֥י עֵדֹתָ֗יו בְּכׇל־לֵ֥ב יִדְרְשֽׁוּהוּ׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "אַ֭ף לֹא־פָעֲל֣וּ עַוְלָ֑ה בִּדְרָכָ֥יו הָלָֽכוּ׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "אַ֭תָּה צִוִּ֥יתָה פִקֻּדֶ֗יךָ לִשְׁמֹ֥ר מְאֹֽד׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "אַ֭חֲלַי יִכֹּ֥נוּ דְרָכָ֗י לִשְׁמֹ֥ר חֻקֶּֽיךָ׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "אָ֥ז לֹא־אֵב֑וֹשׁ בְּ֝הַבִּיטִ֗י אֶל־כׇּל־מִצְוֺתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 7,
      "he": "א֭וֹדְךָ בְּיֹ֣שֶׁר לֵבָ֑ב בְּ֝לׇמְדִ֗י מִשְׁפְּטֵ֥י צִדְקֶֽךָ׃",
      "es": ""
    },
    {
      "num": 8,
      "he": "אֶת־חֻקֶּ֥יךָ אֶשְׁמֹ֑ר אַֽל־תַּעַזְבֵ֥נִי עַד־מְאֹֽד׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 9,
      "he": "בַּמֶּ֣ה יְזַכֶּה־נַּ֭עַר אֶת־אׇרְח֑וֹ לִ֝שְׁמֹ֗ר כִּדְבָרֶֽךָ׃",
      "es": ""
    },
    {
      "num": 10,
      "he": "בְּכׇל־לִבִּ֥י דְרַשְׁתִּ֑יךָ אַל־תַּ֝שְׁגֵּ֗נִי מִמִּצְוֺתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 11,
      "he": "בְּ֭לִבִּי צָפַ֣נְתִּי אִמְרָתֶ֑ךָ לְ֝מַ֗עַן לֹ֣א אֶחֱטָא־לָֽךְ׃",
      "es": ""
    },
    {
      "num": 12,
      "he": "בָּר֖וּךְ אַתָּ֥ה יְהֹוָ֗ה לַמְּדֵ֥נִי חֻקֶּֽיךָ׃",
      "es": ""
    },
    {
      "num": 13,
      "he": "בִּשְׂפָתַ֥י סִפַּ֑רְתִּי כֹּ֝֗ל מִשְׁפְּטֵי־פִֽיךָ׃",
      "es": ""
    },
    {
      "num": 14,
      "he": "בְּדֶ֖רֶךְ עֵדְוֺתֶ֥יךָ שַּׂ֗שְׂתִּי כְּעַ֣ל כׇּל־הֽוֹן׃",
      "es": ""
    },
    {
      "num": 15,
      "he": "בְּפִקּוּדֶ֥יךָ אָשִׂ֑יחָה וְ֝אַבִּ֗יטָה אֹֽרְחֹתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 16,
      "he": "בְּחֻקֹּתֶ֥יךָ אֶֽשְׁתַּעֲשָׁ֑ע לֹ֖א אֶשְׁכַּ֣ח דְּבָרֶֽךָ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 17,
      "he": "גְּמֹ֖ל עַל־עַבְדְּךָ֥ אֶחְיֶ֗ה וְאֶשְׁמְרָ֥ה דְבָרֶֽךָ׃",
      "es": ""
    },
    {
      "num": 18,
      "he": "גַּל־עֵינַ֥י וְאַבִּ֑יטָה נִ֝פְלָא֗וֹת מִתּוֹרָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 19,
      "he": "גֵּ֣ר אָנֹכִ֣י בָאָ֑רֶץ אַל־תַּסְתֵּ֥ר מִ֝מֶּ֗נִּי מִצְוֺתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 20,
      "he": "גָּרְסָ֣ה נַפְשִׁ֣י לְתַאֲבָ֑ה אֶֽל־מִשְׁפָּטֶ֥יךָ בְכׇל־עֵֽת׃",
      "es": ""
    },
    {
      "num": 21,
      "he": "גָּ֭עַרְתָּ זֵדִ֣ים אֲרוּרִ֑ים הַ֝שֹּׁגִ֗ים מִמִּצְוֺתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 22,
      "he": "גַּ֣ל מֵ֭עָלַי חֶרְפָּ֣ה וָב֑וּז כִּ֖י עֵדֹתֶ֣יךָ נָצָֽרְתִּי׃",
      "es": ""
    },
    {
      "num": 23,
      "he": "גַּ֤ם יָשְׁב֣וּ שָׂ֭רִים בִּ֣י נִדְבָּ֑רוּ עַ֝בְדְּךָ֗ יָשִׂ֥יחַ בְּחֻקֶּֽיךָ׃",
      "es": ""
    },
    {
      "num": 24,
      "he": "גַּֽם־עֵ֭דֹתֶיךָ שַׁעֲשֻׁעָ֗י אַנְשֵׁ֥י עֲצָתִֽי׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 25,
      "he": "דָּבְקָ֣ה לֶעָפָ֣ר נַפְשִׁ֑י חַ֝יֵּ֗נִי כִּדְבָרֶֽךָ׃",
      "es": ""
    },
    {
      "num": 26,
      "he": "דְּרָכַ֣י סִ֭פַּרְתִּי וַֽתַּעֲנֵ֗נִי לַמְּדֵ֥נִי חֻקֶּֽיךָ׃",
      "es": ""
    },
    {
      "num": 27,
      "he": "דֶּרֶךְ־פִּקּוּדֶ֥יךָ הֲבִינֵ֑נִי וְ֝אָשִׂ֗יחָה בְּנִפְלְאוֹתֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 28,
      "he": "דָּלְפָ֣ה נַ֭פְשִׁי מִתּוּגָ֑ה קַ֝יְּמֵ֗נִי כִּדְבָרֶֽךָ׃",
      "es": ""
    },
    {
      "num": 29,
      "he": "דֶּֽרֶךְ־שֶׁ֭קֶר הָסֵ֣ר מִמֶּ֑נִּי וְֽתוֹרָתְךָ֥ חׇנֵּֽנִי׃",
      "es": ""
    },
    {
      "num": 30,
      "he": "דֶּֽרֶךְ־אֱמוּנָ֥ה בָחָ֑רְתִּי מִשְׁפָּטֶ֥יךָ שִׁוִּֽיתִי׃",
      "es": ""
    },
    {
      "num": 31,
      "he": "דָּבַ֥קְתִּי בְעֵדְוֺתֶ֑יךָ יְ֝הֹוָ֗ה אַל־תְּבִישֵֽׁנִי׃",
      "es": ""
    },
    {
      "num": 32,
      "he": "דֶּֽרֶךְ־מִצְוֺתֶ֥יךָ אָר֑וּץ כִּ֖י תַרְחִ֣יב לִבִּֽי׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 33,
      "he": "הוֹרֵ֣נִי יְ֭הֹוָה דֶּ֥רֶךְ חֻקֶּ֗יךָ וְאֶצְּרֶ֥נָּה עֵֽקֶב׃",
      "es": ""
    },
    {
      "num": 34,
      "he": "הֲ֭בִינֵנִי וְאֶצְּרָ֥ה תוֹרָתֶ֗ךָ וְאֶשְׁמְרֶ֥נָּה בְכׇל־לֵֽב׃",
      "es": ""
    },
    {
      "num": 35,
      "he": "הַ֭דְרִיכֵנִי בִּנְתִ֣יב מִצְוֺתֶ֑יךָ כִּי־ב֥וֹ חָפָֽצְתִּי׃",
      "es": ""
    },
    {
      "num": 36,
      "he": "הַט־לִ֭בִּי אֶל־עֵדְוֺתֶ֗יךָ וְאַ֣ל אֶל־בָּֽצַע׃",
      "es": ""
    },
    {
      "num": 37,
      "he": "הַעֲבֵ֣ר עֵ֭ינַי מֵרְא֣וֹת שָׁ֑וְא בִּדְרָכֶ֥ךָ חַיֵּֽנִי׃",
      "es": ""
    },
    {
      "num": 38,
      "he": "הָקֵ֣ם לְ֭עַבְדְּךָ אִמְרָתֶ֑ךָ אֲ֝שֶׁ֗ר לְיִרְאָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 39,
      "he": "הַעֲבֵ֣ר חֶ֭רְפָּתִי אֲשֶׁ֣ר יָגֹ֑רְתִּי כִּ֖י מִשְׁפָּטֶ֣יךָ טוֹבִֽים׃",
      "es": ""
    },
    {
      "num": 40,
      "he": "הִ֭נֵּה תָּאַ֣בְתִּי לְפִקֻּדֶ֑יךָ בְּצִדְקָתְךָ֥ חַיֵּֽנִי׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 41,
      "he": "וִיבֹאֻ֣נִי חֲסָדֶ֣ךָ יְהֹוָ֑ה תְּ֝שׁ֥וּעָתְךָ֗ כְּאִמְרָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 42,
      "he": "וְאֶעֱנֶ֣ה חֹרְפִ֣י דָבָ֑ר כִּֽי־בָ֝טַ֗חְתִּי בִּדְבָרֶֽךָ׃",
      "es": ""
    },
    {
      "num": 43,
      "he": "וְֽאַל־תַּצֵּ֬ל מִפִּ֣י דְבַר־אֱמֶ֣ת עַד־מְאֹ֑ד כִּ֖י לְמִשְׁפָּטֶ֣ךָ יִחָֽלְתִּי׃",
      "es": ""
    },
    {
      "num": 44,
      "he": "וְאֶשְׁמְרָ֖ה תוֹרָתְךָ֥ תָמִ֗יד לְעוֹלָ֥ם וָעֶֽד׃",
      "es": ""
    },
    {
      "num": 45,
      "he": "וְאֶתְהַלְּכָ֥ה בָרְחָבָ֑ה כִּ֖י פִקֻּדֶ֣יךָ דָרָֽשְׁתִּי׃",
      "es": ""
    },
    {
      "num": 46,
      "he": "וַאֲדַבְּרָ֣ה בְ֭עֵדֹתֶיךָ נֶ֥גֶד מְלָכִ֗ים וְלֹ֣א אֵבֽוֹשׁ׃",
      "es": ""
    },
    {
      "num": 47,
      "he": "וְאֶשְׁתַּעֲשַׁ֥ע בְּמִצְוֺתֶ֗יךָ אֲשֶׁ֣ר אָהָֽבְתִּי׃",
      "es": ""
    },
    {
      "num": 48,
      "he": "וְאֶשָּֽׂא־כַפַּ֗י אֶֽל־מִ֭צְוֺתֶיךָ אֲשֶׁ֥ר אָהָ֗בְתִּי וְאָשִׂ֥יחָה בְחֻקֶּֽיךָ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 49,
      "he": "זְכֹר־דָּבָ֥ר לְעַבְדֶּ֑ךָ עַ֝֗ל אֲשֶׁ֣ר יִחַלְתָּֽנִי׃",
      "es": ""
    },
    {
      "num": 50,
      "he": "זֹ֣את נֶחָמָתִ֣י בְעׇנְיִ֑י כִּ֖י אִמְרָתְךָ֣ חִיָּֽתְנִי׃",
      "es": ""
    },
    {
      "num": 51,
      "he": "זֵ֭דִים הֱלִיצֻ֣נִי עַד־מְאֹ֑ד מִ֝תּ֥וֹרָתְךָ֗ לֹ֣א נָטִֽיתִי׃",
      "es": ""
    },
    {
      "num": 52,
      "he": "זָ֘כַ֤רְתִּי מִשְׁפָּטֶ֖יךָ מֵעוֹלָ֥ם&thinsp;<small>׀</small>&thinsp;יְהֹוָ֗ה וָאֶתְנֶחָֽם׃",
      "es": ""
    },
    {
      "num": 53,
      "he": "זַלְעָפָ֣ה אֲ֭חָזַתְנִי מֵרְשָׁעִ֑ים עֹ֝זְבֵ֗י תּוֹרָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 54,
      "he": "זְ֭מִרוֹת הָיוּ־לִ֥י חֻקֶּ֗יךָ בְּבֵ֣ית מְגוּרָֽי׃",
      "es": ""
    },
    {
      "num": 55,
      "he": "זָ֘כַ֤רְתִּי בַלַּ֣יְלָה שִׁמְךָ֣ יְהֹוָ֑ה וָ֝אֶשְׁמְרָ֗ה תּוֹרָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 56,
      "he": "זֹ֥את הָיְתָה־לִּ֑י כִּ֖י פִקֻּדֶ֣יךָ נָצָֽרְתִּי׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 57,
      "he": "חֶלְקִ֖י יְהֹוָ֥ה אָמַ֗רְתִּי לִשְׁמֹ֥ר דְּבָרֶֽיךָ׃",
      "es": ""
    },
    {
      "num": 58,
      "he": "חִלִּ֣יתִי פָנֶ֣יךָ בְכׇל־לֵ֑ב חׇ֝נֵּ֗נִי כְּאִמְרָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 59,
