    {
      "num": 3,
      "he": "לָדַ֣עַת בָּאָ֣רֶץ דַּרְכֶּ֑ךָ בְּכׇל־גּ֝וֹיִ֗ם יְשׁוּעָתֶֽךָ׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "יוֹד֖וּךָ עַמִּ֥ים&thinsp;<small>׀</small>&thinsp;אֱלֹהִ֑ים י֝וֹד֗וּךָ עַמִּ֥ים כֻּלָּֽם׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "יִ֥שְׂמְח֥וּ וִירַנְּנ֗וּ לְאֻ֫מִּ֥ים כִּֽי־תִשְׁפֹּ֣ט עַמִּ֣ים מִישֹׁ֑ר וּלְאֻמִּ֓ים&thinsp;<b>׀</b> בָּאָ֖רֶץ תַּנְחֵ֣ם סֶֽלָה׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "יוֹד֖וּךָ עַמִּ֥ים&thinsp;<small>׀</small>&thinsp;אֱלֹהִ֑ים י֝וֹד֗וּךָ עַמִּ֥ים כֻּלָּֽם׃",
      "es": ""
