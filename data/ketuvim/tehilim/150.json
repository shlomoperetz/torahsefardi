  "verses": [
    {
      "num": 1,
      "he": "הַ֥לְלוּ<span class=\"mam-implicit-maqaf\">־</span>יָ֨הּ&thinsp;<b>׀</b> הַֽלְלוּ־אֵ֥ל בְּקׇדְשׁ֑וֹ הַֽ֝לְל֗וּהוּ בִּרְקִ֥יעַ עֻזּֽוֹ׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "הַלְל֥וּהוּ בִגְבוּרֹתָ֑יו הַ֝לְל֗וּהוּ כְּרֹ֣ב גֻּדְלֽוֹ׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "הַ֭לְלוּהוּ בְּתֵ֣קַע שׁוֹפָ֑ר הַ֝לְל֗וּהוּ בְּנֵ֣בֶל וְכִנּֽוֹר׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "הַ֭לְלוּהוּ בְּתֹ֣ף וּמָח֑וֹל הַֽ֝לְל֗וּהוּ בְּמִנִּ֥ים וְעֻגָֽב׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "הַלְל֥וּהוּ בְצִלְצְלֵי־שָׁ֑מַע הַֽ֝לְל֗וּהוּ בְּֽצִלְצְלֵ֥י תְרוּעָֽה׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "כֹּ֣ל הַ֭נְּשָׁמָה תְּהַלֵּ֥ל יָ֗הּ הַֽלְלוּ־יָֽהּ׃",
      "es": ""
    }
  ]
