{
  "book": "divreiy_hayamim1",
  "book_he": "דִּבְרֵי הַיָּמִים א",
  "book_es": "1 Crónicas",
  "chapter": 24,
  "title_he": "דברי הימים א",
  "verses": [
    {
      "num": 1,
      "he": "וְלִבְנֵ֥י אַהֲרֹ֖ן מַחְלְקוֹתָ֑ם בְּנֵ֣י אַהֲרֹ֔ן נָדָב֙ וַאֲבִיה֔וּא אֶלְעָזָ֖ר וְאִיתָמָֽר׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "וַיָּ֨מׇת נָדָ֤ב וַֽאֲבִיהוּא֙ לִפְנֵ֣י אֲבִיהֶ֔ם וּבָנִ֖ים לֹא־הָי֣וּ לָהֶ֑ם וַֽיְכַהֲנ֔וּ אֶלְעָזָ֖ר וְאִיתָמָֽר׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "וַיֶּחָלְקֵ֣ם דָּוִ֔יד וְצָדוֹק֙ מִן־בְּנֵ֣י אֶלְעָזָ֔ר וַאֲחִימֶ֖לֶךְ מִן־בְּנֵ֣י אִיתָמָ֑ר לִפְקֻדָּתָ֖ם בַּעֲבֹדָתָֽם׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "וַיִּמָּצְא֣וּ בְֽנֵי־אֶלְעָזָ֡ר רַבִּ֞ים לְרָאשֵׁ֧י הַגְּבָרִ֛ים מִן־בְּנֵ֥י אִיתָמָ֖ר וַֽיַּחְלְק֑וּם לִבְנֵ֨י אֶלְעָזָ֜ר רָאשִׁ֤ים לְבֵית־אָבוֹת֙ שִׁשָּׁ֣ה עָשָׂ֔ר וְלִבְנֵ֧י אִיתָמָ֛ר לְבֵ֥ית אֲבוֹתָ֖ם שְׁמוֹנָֽה׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "וַיַּחְלְק֥וּם בְּגוֹרָל֖וֹת אֵ֣לֶּה עִם־אֵ֑לֶּה כִּֽי־הָי֤וּ שָׂרֵי־קֹ֙דֶשׁ֙ וְשָׂרֵ֣י הָאֱלֹהִ֔ים מִבְּנֵ֥י אֶלְעָזָ֖ר וּבִבְנֵ֥י אִיתָמָֽר׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 6,
      "he": "וַֽיִּכְתְּבֵ֡ם שְֽׁמַעְיָה֩ בֶן־נְתַנְאֵ֨ל הַסּוֹפֵ֜ר מִן־הַלֵּוִ֗י לִפְנֵ֨י הַמֶּ֤לֶךְ וְהַשָּׂרִים֙ וְצָד֣וֹק הַכֹּהֵ֗ן וַאֲחִימֶ֙לֶךְ֙ בֶּן־אֶבְיָתָ֔ר וְרָאשֵׁי֙ הָאָב֔וֹת לַכֹּהֲנִ֖ים וְלַלְוִיִּ֑ם בֵּֽית־אָ֣ב אֶחָ֗ד אָחֻז֙ לְאֶלְעָזָ֔ר וְאָחֻ֥ז&thinsp;<small>׀</small>&thinsp;אָחֻ֖ז לְאִיתָמָֽר׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 7,
      "he": "וַיֵּצֵ֞א הַגּוֹרָ֤ל הָֽרִאשׁוֹן֙ לִיה֣וֹיָרִ֔יב&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לִידַֽעְיָ֖ה הַשֵּׁנִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 8,
      "he": "לְחָרִם֙ הַשְּׁלִישִׁ֔י&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לִשְׂעֹרִ֖ים הָרְבִעִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 9,
      "he": "לְמַלְכִּיָּה֙ הַחֲמִישִׁ֔י&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְמִיָּמִ֖ן הַשִּׁשִּֽׁי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 10,
      "he": "לְהַקּוֹץ֙ הַשְּׁבִעִ֔י&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לַאֲבִיָּ֖ה הַשְּׁמִינִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 11,
      "he": "לְיֵשׁ֙וּעַ֙ הַתְּשִׁעִ֔י&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לִשְׁכַנְיָ֖הוּ הָעֲשִׂרִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 12,
      "he": "לְאֶלְיָשִׁיב֙ עַשְׁתֵּ֣י עָשָׂ֔ר&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְיָקִ֖ים שְׁנֵ֥ים עָשָֽׂר׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 13,
      "he": "לְחֻפָּה֙ שְׁלֹשָׁ֣ה עָשָׂ֔ר&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְיֶשֶׁבְאָ֖ב אַרְבָּעָ֥ה עָשָֽׂר׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 14,
      "he": "לְבִלְגָּה֙ חֲמִשָּׁ֣ה עָשָׂ֔ר&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְאִמֵּ֖ר שִׁשָּׁ֥ה עָשָֽׂר׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 15,
      "he": "לְחֵזִיר֙ שִׁבְעָ֣ה עָשָׂ֔ר&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְהַפִּצֵּ֖ץ שְׁמוֹנָ֥ה עָשָֽׂר׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 16,
      "he": "לִֽפְתַחְיָה֙ תִּשְׁעָ֣ה עָשָׂ֔ר&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לִֽיחֶזְקֵ֖אל הָעֶשְׂרִֽים׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 17,
      "he": "לְיָכִין֙ אֶחָ֣ד וְעֶשְׂרִ֔ים&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְגָמ֖וּל שְׁנַ֥יִם וְעֶשְׂרִֽים׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 18,
      "he": "לִדְלָיָ֙הוּ֙ שְׁלֹשָׁ֣ה וְעֶשְׂרִ֔ים&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לְמַעַזְיָ֖הוּ אַרְבָּעָ֥ה וְעֶשְׂרִֽים׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 19,
      "he": "אֵ֣לֶּה פְקֻדָּתָ֞ם לַעֲבֹדָתָ֗ם לָב֤וֹא לְבֵית־יְהֹוָה֙ כְּמִשְׁפָּטָ֔ם בְּיַ֖ד אַהֲרֹ֣ן אֲבִיהֶ֑ם כַּאֲשֶׁ֣ר צִוָּ֔הוּ יְהֹוָ֖ה אֱלֹהֵ֥י יִשְׂרָאֵֽל׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    },
    {
      "num": 20,
      "he": "וְלִבְנֵ֥י לֵוִ֖י הַנּוֹתָרִ֑ים לִבְנֵ֤י עַמְרָם֙ שֽׁוּבָאֵ֔ל לִבְנֵ֥י שׁוּבָאֵ֖ל יֶחְדְּיָֽהוּ׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 21,
      "he": "לִרְחַבְיָ֑הוּ לִבְנֵ֣י רְחַבְיָ֔הוּ הָרֹ֖אשׁ יִשִּׁיָּֽה׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 22,
      "he": "לַיִּצְהָרִ֣י שְׁלֹמ֔וֹת לִבְנֵ֥י שְׁלֹמ֖וֹת יָֽחַת׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 23,
      "he": "וּבְנָ֖י יְרִיָּ֑הוּ אֲמַרְיָ֙הוּ֙ הַשֵּׁנִ֔י יַחֲזִיאֵל֙ הַשְּׁלִישִׁ֔י יְקַמְעָ֖ם הָרְבִיעִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 24,
      "he": "בְּנֵ֤י עֻזִּיאֵל֙ מִיכָ֔ה לִבְנֵ֥י מִיכָ֖ה <span class=\"mam-kq\"><span class=\"mam-kq-k\">(שמור)</span> <span class=\"mam-kq-q\">[שָׁמִֽיר]</span></span>׃",
      "es": ""
    },
    {
      "num": 25,
      "he": "אֲחִ֤י מִיכָה֙ יִשִּׁיָּ֔ה&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;לִבְנֵ֥י יִשִּׁיָּ֖ה זְכַרְיָֽהוּ׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 26,
      "he": "בְּנֵ֤י מְרָרִי֙ מַחְלִ֣י וּמוּשִׁ֔י&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;בְּנֵ֖י יַעֲזִיָּ֥הוּ בְנֽוֹ׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 27,
      "he": "בְּנֵ֖י מְרָרִ֑י לְיַעֲזִיָּ֣הוּ בְנ֔וֹ וְשֹׁ֥הַם וְזַכּ֖וּר וְעִבְרִֽי׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 28,
      "he": "לְמַחְלִי֙ אֶלְעָזָ֔ר וְלֹא־הָ֥יָה ל֖וֹ בָּנִֽים׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 29,
      "he": "לְקִ֖ישׁ בְּנֵי־קִ֥ישׁ יְרַחְמְאֵֽל׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    },
    {
      "num": 30,
      "he": "וּבְנֵ֣י מוּשִׁ֔י מַחְלִ֥י וְעֵ֖דֶר וִירִימ֑וֹת אֵ֛לֶּה בְּנֵ֥י הַלְוִיִּ֖ם לְבֵ֥ית אֲבֹתֵיהֶֽם׃",
      "es": ""
    },
    {
      "num": 31,
      "he": "וַיַּפִּ֩ילוּ֩ גַם־הֵ֨ם גּוֹרָל֜וֹת לְעֻמַּ֣ת&thinsp;<b>׀</b> אֲחֵיהֶ֣ם בְּנֵי־אַהֲרֹ֗ן לִפְנֵ֨י דָוִ֤יד הַמֶּ֙לֶךְ֙ וְצָד֣וֹק וַאֲחִימֶ֔לֶךְ וְרָאשֵׁי֙ הָאָב֔וֹת לַכֹּהֲנִ֖ים וְלַלְוִיִּ֑ם אָב֣וֹת הָרֹ֔אשׁ לְעֻמַּ֖ת אָחִ֥יו הַקָּטָֽן׃&nbsp;<span class=\"mam-spi-samekh\">{ס}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;",
      "es": ""
    }
  ]
}