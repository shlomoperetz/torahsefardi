{
  "book": "iyov",
  "book_he": "אִיּוֹב",
  "book_es": "Job",
  "chapter": 26,
  "title_he": "איוב",
  "verses": [
    {
      "num": 1,
      "he": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר׃",
      "es": ""
    },
    {
      "num": 2,
      "he": "מֶה־עָזַ֥רְתָּ לְלֹא־כֹ֑חַ ה֝וֹשַׁ֗עְתָּ זְר֣וֹעַ לֹא־עֹֽז׃",
      "es": ""
    },
    {
      "num": 3,
      "he": "מַה־יָּ֭עַצְתָּ לְלֹ֣א חׇכְמָ֑ה וְ֝תֻשִׁיָּ֗ה לָרֹ֥ב הוֹדָֽעְתָּ׃",
      "es": ""
    },
    {
      "num": 4,
      "he": "אֶת־מִ֭י הִגַּ֣דְתָּ מִלִּ֑ין וְנִשְׁמַת־מִ֝֗י יָצְאָ֥ה מִמֶּֽךָּ׃",
      "es": ""
    },
    {
      "num": 5,
      "he": "הָרְפָאִ֥ים יְחוֹלָ֑לוּ מִתַּ֥חַת מַ֝֗יִם וְשֹׁכְנֵיהֶֽם׃",
      "es": ""
    },
    {
      "num": 6,
      "he": "עָר֣וֹם שְׁא֣וֹל נֶגְדּ֑וֹ וְאֵ֥ין כְּ֝ס֗וּת לָאֲבַדּֽוֹן׃",
      "es": ""
    },
    {
      "num": 7,
      "he": "נֹטֶ֣ה צָפ֣וֹן עַל־תֹּ֑הוּ תֹּ֥לֶה אֶ֝֗רֶץ עַל־בְּלִי־מָֽה׃",
      "es": ""
    },
    {
      "num": 8,
      "he": "צֹרֵֽר־מַ֥יִם בְּעָבָ֑יו וְלֹֽא־נִבְקַ֖ע עָנָ֣ן תַּחְתָּֽם׃",
      "es": ""
    },
    {
      "num": 9,
      "he": "מְאַחֵ֥ז פְּנֵֽי־כִסֵּ֑ה פַּרְשֵׁ֖ז עָלָ֣יו עֲנָנֽוֹ׃",
      "es": ""
    },
    {
      "num": 10,
      "he": "חֹֽק־חָ֭ג עַל־פְּנֵי־מָ֑יִם עַד־תַּכְלִ֖ית א֣וֹר עִם־חֹֽשֶׁךְ׃",
      "es": ""
    },
    {
      "num": 11,
      "he": "עַמּוּדֵ֣י שָׁמַ֣יִם יְרוֹפָ֑פוּ וְ֝יִתְמְה֗וּ מִגַּעֲרָתֽוֹ׃",
      "es": ""
    },
    {
      "num": 12,
      "he": "בְּ֭כֹחוֹ רָגַ֣ע הַיָּ֑ם <span class=\"mam-kq\"><span class=\"mam-kq-k\">(ובתובנתו)</span> <span class=\"mam-kq-q\">[וּ֝בִתְבוּנָת֗וֹ]</span></span> מָ֣חַץ רָֽהַב׃",
      "es": ""
    },
    {
      "num": 13,
      "he": "בְּ֭רוּחוֹ שָׁמַ֣יִם שִׁפְרָ֑ה חֹלְלָ֥ה יָ֝ד֗וֹ נָחָ֥שׁ בָּרִֽחַ׃",
      "es": ""
    },
    {
      "num": 14,
      "he": "הֶן־אֵ֤לֶּה&thinsp;<b>׀</b> קְצ֬וֹת דְּרָכָ֗ו וּמַה־שֵּׁ֣מֶץ דָּ֭בָר נִשְׁמַע־בּ֑וֹ וְרַ֥עַם <span class=\"mam-kq-trivial\">גְּ֝בוּרֹתָ֗ו</span> מִ֣י יִתְבּוֹנָֽן׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "es": ""
    }
  ]
}