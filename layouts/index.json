{"section":{{ $section | jsonify }},"book":{{ $book | jsonify }},"chapter":{{ $ch.chapter }},"url":"/{{ $section }}/{{ $book }}/{{ $k }}/","book_he":{{ $ch.book_he | jsonify }},"book_es":{{ $ch.book_es | jsonify }},"title_he":{{ $ch.title_he | jsonify }},"es_preview":{{ if $ch.verses }}{{ with index $ch.verses 0 }}{{ .es | jsonify }}{{ else }}""{{ end }}{{ else }}""{{ end }}}
{{- end -}}
{{- end -}}
{{- end }}
]
